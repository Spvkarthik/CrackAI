## Backend configuration
PORT=5000
JWT_SECRET=dev-secret-change-me

## Roboflow Workflows (Serverless Hosted API)
# Your Roboflow API key (rotate if you ever pasted it publicly)
ROBOFLOW_API_KEY=your_key_here

# Workflow endpoint parts:
#   POST https://serverless.roboflow.com/<workspace>/workflows/<workflow_id>
ROBOFLOW_WORKSPACE=qr-code-detection
ROBOFLOW_WORKFLOW_ID=general-segmentation-api-4

# Optional: filter classes (passed into your workflow)
ROBOFLOW_CLASSES=crack

